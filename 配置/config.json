{
  "plugin": {
    "name": "CAD排砖插件",
    "version": "1.1.0",
    "author": "Fanben",
    "description": "AutoCAD .NET 排砖插件 v1.1 — 新增3D可视化（Solid3d实体 + 拉伸体）"
  },
  "defaultSettings": {
    "brickSpec": "600×300",
    "joint": {
      "horizontal": 2.0,
      "vertical": 2.0
    },
    "pattern": "Straight",
    "startPoint": "Center",
    "cornerDirection": "BottomLeft",
    "minCutRatio": 0.33,
    "preferFullTile": true,
    "confirmBeforeCut": true,
    "autoDetectOpenings": true,
    "presentation": {
      "outline": true,
      "block": true,
      "hatch": true
    }
  },
  "3dSettings": {
    "enabled": false,
    "wallHeight": 2800,
    "wallThickness": 240,
    "verticalStart": "Bottom",
    "preciseTrim": false,
    "comment": "3D可视化：墙砖→Solid3d实体 / 地砖→拉伸体"
  },
  "export": {
    "excelPath": "桌面",
    "includeCutDetails": true,
    "includePlacementData": true,
    "includeVolumeStats": true
  }
}
